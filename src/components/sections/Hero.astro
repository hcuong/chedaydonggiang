---
import { Image } from 'astro:assets';
import { site } from "../../data/site";
import chedaySrc from '../../assets/cheday_cotu.jpg';
---

<section class="hero">
  <div class="hero-decor" aria-hidden="true">
    <span style="height: 40px; background: var(--sage-soft);"></span>
    <span style="height: 56px; background: var(--terracotta);"></span>
    <span style="height: 72px; background: var(--gold-rich);"></span>
    <span style="height: 88px; background: var(--forest-deep);"></span>
    <span style="height: 64px; background: var(--gold);"></span>
  </div>

  <div class="container inner">
    <div class="hero-grid">
      <div>
        <div class="hero-eyebrow eyebrow">
          Chè Dây Ra Zéh · OCOP 4 Sao Quảng Nam
        </div>
        <h1>Chè Dây<br />Đông Giang</h1>
        <p class="subtitle">Hái tay bởi người Cơ Tu, từ rừng miền Trung.</p>
        <p class="lede">
          Chỉ <strong>10cm ngọn đầu tiên</strong> — phần lá non nhất của cây chè dây
          mọc hoang trên độ cao 800–1.200m. Sao ủ 8 tiếng theo công thức truyền thống,
          tạo lớp phấn trắng tự nhiên đặc trưng.
        </p>
        <div class="hero-actions">
          <a href={site.shopeeUrl} class="btn btn-primary"
            >Mua trên Shopee — 65.000đ</a
          >
          <a href="#story" class="btn btn-secondary">Xem câu chuyện</a>
        </div>
        <div class="hero-trust">
          <span class="stars">★★★★★</span>
          <span class="meta">4.9 / 5 · 200+ đánh giá</span>
          <span class="meta">·</span>
          <span class="meta">Truy xuất QR từng lô</span>
        </div>
        <div class="hero-script">{site.tagline}</div>
      </div>

      <div class="hero-visual">
        <Image
          src={chedaySrc}
          alt="Người phụ nữ Cơ Tu hái chè dây tại rừng Đông Giang, Quảng Nam"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
