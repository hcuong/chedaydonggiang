---
import { Image } from 'astro:assets';
import { storyStepsSimple } from '../../../data/story-simple';
import rungSrc from '../../../assets/rung_dong_giang.jpg';
import ngonSrc from '../../../assets/ngon_che_day.jpg';
import lopMocSrc from '../../../assets/lop_moc_che_day.webp';

const imageMap = {
  'img-mountain': rungSrc,
  'img-leaf': ngonSrc,
  'img-roast': lopMocSrc,
};
---
<section class="story" id="story">
  <header class="story-header">
    <h2 class="story-title">Chuyện một loại lá ở rừng Đông Giang</h2>
  </header>

  <div class="story-steps">
    {storyStepsSimple.map(step => (
      <article class="story-step">
        <div class="image">
          <Image src={imageMap[step.imageClass as keyof typeof imageMap]} alt={step.pin} />
          <span class="pin">{step.pin}</span>
        </div>
        <div class="text">
          <div class="number">{step.number}</div>
          <h3>{step.title}</h3>
          {step.body.map(para => <p set:html={para} />)}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .story { padding: 104px 0 88px; }
  .story-header { max-width: var(--container); margin: 0 auto 72px; padding: 0 24px; }
  .story-steps { max-width: var(--container); margin: 0 auto; padding: 0 24px; gap: 80px; }
  .story-step .image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
</style>
