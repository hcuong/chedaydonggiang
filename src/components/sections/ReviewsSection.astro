---
import { reviews } from '../../data/reviews';
---
<section class="reviews" id="reviews">
  <div class="container">
    <div class="section-header">
      <span class="script" style="font-size: 28px; display: block; margin-bottom: 4px;">Khách hàng nói gì</span>
      <h2>Cảm nhận từ những người đã thử</h2>
    </div>

    <div class="reviews-grid">
      {reviews.map(r => (
        <article class="review">
          <div class="stars">{'★'.repeat(r.stars)}</div>
          <p>{r.text}</p>
          <div class="author">
            <div class="avatar">{r.avatar}</div>
            <div>
              <div class="name">{r.name}</div>
              <div class="city">{r.city}</div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
